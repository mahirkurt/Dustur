{
  "$description": "DÜSTUR semantic surface jetonları · yüzeyler, kenarlıklar (metin renkleri için ink.* primitive'lerini doğrudan kullanın)",
  "surface": {
    "page": {
      "bg":   { "$type": "color", "$value": "{kagit.sayfa}",  "$description": "Specimen miras sayfa zemini" },
      "deep": { "$type": "color", "$value": "{kagit.deep}",   "$description": "Sayfa zemini koyu varyant" }
    },
    "panel": {
      "bg":     { "$type": "color", "$value": "{kagit.panel}",  "$description": "Panel · kart · aside bg" },
      "subtle": { "$type": "color", "$value": "{kagit.subtle}", "$description": "Subtle panel bg" }
    },
    "stripe": { "$type": "color", "$value": "{kagit.stripe}", "$description": "Zebra çizgili yüzey" }
  },
  "border": {
    "subtle":  { "$type": "color", "$value": "{kagit.border-subtle}",  "$description": "Subtle · ince ayraç" },
    "default": { "$type": "color", "$value": "{kagit.border-default}", "$description": "Default UI border" },
    "strong":  { "$type": "color", "$value": "{color.gri.7}",          "$description": "Strong border" }
  },
  "selection": {
    "bg":   { "$type": "color", "$value": "{color.turkuvaz.9}", "$description": "Text selection bg" },
    "text": { "$type": "color", "$value": "{kagit.sayfa}",      "$description": "Text selection foreground" }
  }
}
