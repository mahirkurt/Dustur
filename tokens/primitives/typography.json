{
  "$description": "DÜSTUR primitive tipografi jetonları · 3 değişken (variable) font ailesi · optical sizing, weight, SOFT, WONK eksen değerleri",
  "family": {
    "fr": {
      "$type": "fontFamily",
      "$value": ["Fraunces", "Georgia", "serif"],
      "$description": "Variable serif · ana mevzuat tipografisi · opsz / wght / SOFT / WONK eksenleri · SIL OFL 1.1"
    },
    "as": {
      "$type": "fontFamily",
      "$value": ["Albert Sans", "system-ui", "sans-serif"],
      "$description": "Variable sans · UI · etiket · navigasyon · SIL OFL 1.1"
    },
    "mo": {
      "$type": "fontFamily",
      "$value": ["Recursive", "ui-monospace", "monospace"],
      "$description": "Variable mono · URI · kanun no · veri ifadeleri · MONO eksen sabit 1"
    }
  },
  "fr": {
    "$description": "Fraunces variable axis primitives · OpenType opsz/wght/SOFT/WONK standardı",
    "opsz": {
      "9":   { "$type": "number", "$value": 9,   "$description": "Açıklama düzlemi · footnote / dipnot" },
      "14":  { "$type": "number", "$value": 14,  "$description": "Body düzlemi · paragraf metni" },
      "20":  { "$type": "number", "$value": 20,  "$description": "Lead düzlemi · giriş paragrafı" },
      "32":  { "$type": "number", "$value": 32,  "$description": "Sub-head düzlemi · alt başlık" },
      "36":  { "$type": "number", "$value": 36,  "$description": "Sub-head büyük" },
      "60":  { "$type": "number", "$value": 60,  "$description": "Title düzlemi · sayfa başlığı" },
      "72":  { "$type": "number", "$value": 72,  "$description": "Hero title düzlemi · yüzey başlık" },
      "96":  { "$type": "number", "$value": 96,  "$description": "Display düzlemi · bölüm başlığı" },
      "144": { "$type": "number", "$value": 144, "$description": "Display max · ekran/kapak başlığı" }
    },
    "wght": {
      "300": { "$type": "number", "$value": 300, "$description": "Light" },
      "400": { "$type": "number", "$value": 400, "$description": "Normal" },
      "500": { "$type": "number", "$value": 500, "$description": "Medium" },
      "600": { "$type": "number", "$value": 600, "$description": "Semibold" },
      "700": { "$type": "number", "$value": 700, "$description": "Bold" },
      "800": { "$type": "number", "$value": 800, "$description": "Extrabold" }
    },
    "soft": {
      "0":   { "$type": "number", "$value": 0,   "$description": "SOFT keskin · klasik serif" },
      "25":  { "$type": "number", "$value": 25,  "$description": "SOFT hafif yumuşatma" },
      "50":  { "$type": "number", "$value": 50,  "$description": "SOFT tipografik sıcaklık" },
      "100": { "$type": "number", "$value": 100, "$description": "SOFT max yumuşaklık" }
    },
    "wonk": {
      "0": { "$type": "number", "$value": 0, "$description": "WONK kapalı · disiplinli formlar" },
      "1": { "$type": "number", "$value": 1, "$description": "WONK eccentric · karakter taşıyan formlar" }
    }
  },
  "as": {
    "$description": "Albert Sans variable axis primitives",
    "wght": {
      "400": { "$type": "number", "$value": 400, "$description": "Normal" },
      "500": { "$type": "number", "$value": 500, "$description": "Medium · navigasyon" },
      "600": { "$type": "number", "$value": 600, "$description": "Semibold · etiket" },
      "700": { "$type": "number", "$value": 700, "$description": "Bold · rozet" }
    }
  },
  "mo": {
    "$description": "Recursive variable axis primitives",
    "mono":  { "$type": "number", "$value": 1, "$description": "MONO sabit · klasik monospace (Recursive Mono)" },
    "casual": { "$type": "number", "$value": 0, "$description": "Linear · sabit / disiplinli" },
    "wght": {
      "400": { "$type": "number", "$value": 400 },
      "500": { "$type": "number", "$value": 500 },
      "600": { "$type": "number", "$value": 600 },
      "700": { "$type": "number", "$value": 700 }
    }
  },
  "letter-spacing": {
    "tightest":  { "$type": "dimension", "$value": "-0.045em", "$description": "Display başlık" },
    "tighter":   { "$type": "dimension", "$value": "-0.025em", "$description": "Section başlık" },
    "tight":     { "$type": "dimension", "$value": "-0.012em", "$description": "Sub-head" },
    "normal":    { "$type": "dimension", "$value": "0", "$description": "Body" },
    "wide":      { "$type": "dimension", "$value": "0.06em", "$description": "URI / mono" },
    "wider":     { "$type": "dimension", "$value": "0.14em", "$description": "Rozet · etiket · all-caps" },
    "widest":    { "$type": "dimension", "$value": "0.25em", "$description": "Üst etiket · eyebrow" },
    "ultra":     { "$type": "dimension", "$value": "0.32em", "$description": "Cover eyebrow · max tracking" }
  },
  "line-height": {
    "tight":     { "$type": "number", "$value": 1.0,  "$description": "Display başlık" },
    "snug":      { "$type": "number", "$value": 1.2,  "$description": "Sub-head" },
    "normal":    { "$type": "number", "$value": 1.5,  "$description": "Lead paragraf" },
    "relaxed":   { "$type": "number", "$value": 1.62, "$description": "Body · mevzuat metni" },
    "loose":     { "$type": "number", "$value": 1.7,  "$description": "Akıcı uzun metin" }
  }
}
