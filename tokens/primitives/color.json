{
  "$description": "DÜSTUR primitive renk birincilleri · 6 aile × 12 step = 72 jeton · LCH renk uzayında türetildi · Radix Renkler mimarisi",
  "$extensions": {
    "tr.tcm.spec": "v1.0.0",
    "tr.tcm.scale": "radix-12-step-lch"
  },
  "color": {
    "tbk": {
      "$description": "Türk Bayrağı Kırmızısı · TS 715/2010 standart · Anayasa kademesi tanımlayıcı renk",
      "$extensions": {
        "tr.tcm.kaynak": "TS 715/2010 · Türk Standardları Enstitüsü",
        "tr.tcm.kilit": "LOCKED",
        "tr.tcm.tier": "anayasa"
      },
      "1":  { "$type": "color", "$value": "#FFFCFC", "$description": "App background",        "$extensions": { "tr.tcm.rol": "app-bg",         "tr.tcm.wcag.on-ink-1": 19.5 } },
      "2":  { "$type": "color", "$value": "#FFF7F7", "$description": "Subtle background",     "$extensions": { "tr.tcm.rol": "subtle-bg" } },
      "3":  { "$type": "color", "$value": "#FEEBEC", "$description": "Element background",    "$extensions": { "tr.tcm.rol": "element-bg" } },
      "4":  { "$type": "color", "$value": "#FDD8DA", "$description": "Hover element bg",      "$extensions": { "tr.tcm.rol": "hover-bg" } },
      "5":  { "$type": "color", "$value": "#FBC0C3", "$description": "Active element bg",     "$extensions": { "tr.tcm.rol": "active-bg" } },
      "6":  { "$type": "color", "$value": "#F89DA2", "$description": "Subtle border",         "$extensions": { "tr.tcm.rol": "subtle-border" } },
      "7":  { "$type": "color", "$value": "#F5717A", "$description": "UI element border",     "$extensions": { "tr.tcm.rol": "ui-border" } },
      "8":  { "$type": "color", "$value": "#EE3F4A", "$description": "Hover border",          "$extensions": { "tr.tcm.rol": "hover-border" } },
      "9":  { "$type": "color", "$value": "#E30A17", "$description": "Solid base · TS 715/2010 · Türk Bayrağı Kırmızısı kanonik referans", "$extensions": { "tr.tcm.rol": "solid-base", "tr.tcm.kilit": "LOCKED", "tr.tcm.kaynak": "TS 715/2010" } },
      "10": { "$type": "color", "$value": "#C40612", "$description": "Hover solid",           "$extensions": { "tr.tcm.rol": "hover-solid" } },
      "11": { "$type": "color", "$value": "#A1050F", "$description": "Low-contrast text",     "$extensions": { "tr.tcm.rol": "low-contrast-text" } },
      "12": { "$type": "color", "$value": "#5D0107", "$description": "High-contrast text",    "$extensions": { "tr.tcm.rol": "high-contrast-text" } }
    },
    "turkuvaz": {
      "$description": "Anadolu Selçuklu Turkuvazı · Karatay Medrese 1251 referans · Kanun · Yönetmelik kademesi tanımlayıcı renk",
      "$extensions": {
        "tr.tcm.kaynak": "Karatay Medresesi · 1251 · Konya çini referans",
        "tr.tcm.kilit": "LOCKED",
        "tr.tcm.tier": "kanun"
      },
      "1":  { "$type": "color", "$value": "#F7FCFC", "$description": "App background",       "$extensions": { "tr.tcm.rol": "app-bg" } },
      "2":  { "$type": "color", "$value": "#EBF6F6", "$description": "Subtle background",    "$extensions": { "tr.tcm.rol": "subtle-bg" } },
      "3":  { "$type": "color", "$value": "#D7EDEE", "$description": "Element background",   "$extensions": { "tr.tcm.rol": "element-bg" } },
      "4":  { "$type": "color", "$value": "#B9E0E1", "$description": "Hover element bg",     "$extensions": { "tr.tcm.rol": "hover-bg" } },
      "5":  { "$type": "color", "$value": "#94CFD0", "$description": "Active element bg",    "$extensions": { "tr.tcm.rol": "active-bg" } },
      "6":  { "$type": "color", "$value": "#6BB9BB", "$description": "Subtle border",        "$extensions": { "tr.tcm.rol": "subtle-border" } },
      "7":  { "$type": "color", "$value": "#43A1A2", "$description": "UI element border · Yönetmelik mührü", "$extensions": { "tr.tcm.rol": "ui-border", "tr.tcm.tier": "yonetmelik" } },
      "8":  { "$type": "color", "$value": "#298F90", "$description": "Hover border",         "$extensions": { "tr.tcm.rol": "hover-border" } },
      "9":  { "$type": "color", "$value": "#1A8B8C", "$description": "Solid base · Anadolu Selçuklu kanonik referans · Kanun mührü", "$extensions": { "tr.tcm.rol": "solid-base", "tr.tcm.kilit": "LOCKED" } },
      "10": { "$type": "color", "$value": "#137070", "$description": "Hover solid · cross-reference link", "$extensions": { "tr.tcm.rol": "hover-solid" } },
      "11": { "$type": "color", "$value": "#0C5455", "$description": "Low-contrast text · AAA contrast", "$extensions": { "tr.tcm.rol": "low-contrast-text", "tr.tcm.wcag.aaa": true } },
      "12": { "$type": "color", "$value": "#053334", "$description": "High-contrast text",   "$extensions": { "tr.tcm.rol": "high-contrast-text" } }
    },
    "bordo": {
      "$description": "Düstûr Bordo · Cumhurbaşkanlığı Kararnamesi (CBK) kademesi tanımlayıcı renk",
      "$extensions": {
        "tr.tcm.kaynak": "Yürütme mührü teamülü",
        "tr.tcm.kilit": "LOCKED",
        "tr.tcm.tier": "cbk"
      },
      "1":  { "$type": "color", "$value": "#FCFAFA", "$description": "App background" },
      "2":  { "$type": "color", "$value": "#F8F2F2", "$description": "Subtle background" },
      "3":  { "$type": "color", "$value": "#EFE0E0", "$description": "Element background · CBK rozet bg", "$extensions": { "tr.tcm.rol": "rozet-bg" } },
      "4":  { "$type": "color", "$value": "#E0C3C3", "$description": "Hover element bg" },
      "5":  { "$type": "color", "$value": "#CCA1A2", "$description": "Active element bg" },
      "6":  { "$type": "color", "$value": "#B17B7C", "$description": "Subtle border" },
      "7":  { "$type": "color", "$value": "#945858", "$description": "UI element border" },
      "8":  { "$type": "color", "$value": "#763A3B", "$description": "Hover border" },
      "9":  { "$type": "color", "$value": "#5C1A1B", "$description": "Solid base · CBK mührü",         "$extensions": { "tr.tcm.kilit": "LOCKED" } },
      "10": { "$type": "color", "$value": "#4A1314", "$description": "Hover solid · visited link" },
      "11": { "$type": "color", "$value": "#3A0D0D", "$description": "Low-contrast text · AAA",         "$extensions": { "tr.tcm.wcag.aaa": true } },
      "12": { "$type": "color", "$value": "#260606", "$description": "High-contrast text" }
    },
    "lacivert": {
      "$description": "Cumhuriyet Lacivert · Anayasa Mahkemesi (AYM) ve devlet teamülü tanımlayıcı renk",
      "$extensions": {
        "tr.tcm.kaynak": "Devlet teamülü · cumhuriyet sembolizmi",
        "tr.tcm.kilit": "LOCKED",
        "tr.tcm.tier": "aym"
      },
      "1":  { "$type": "color", "$value": "#FBFCFE", "$description": "App background" },
      "2":  { "$type": "color", "$value": "#F2F5FB", "$description": "Subtle background" },
      "3":  { "$type": "color", "$value": "#E1E8F4", "$description": "Element background · AYM rozet bg" },
      "4":  { "$type": "color", "$value": "#C8D4EB", "$description": "Hover element bg" },
      "5":  { "$type": "color", "$value": "#A5B7DD", "$description": "Active element bg" },
      "6":  { "$type": "color", "$value": "#7A93CB", "$description": "Subtle border" },
      "7":  { "$type": "color", "$value": "#4F6FB5", "$description": "UI element border" },
      "8":  { "$type": "color", "$value": "#284C97", "$description": "Hover border" },
      "9":  { "$type": "color", "$value": "#002664", "$description": "Solid base · AYM kanonik referans", "$extensions": { "tr.tcm.kilit": "LOCKED" } },
      "10": { "$type": "color", "$value": "#001E53", "$description": "Hover solid" },
      "11": { "$type": "color", "$value": "#001640", "$description": "Low-contrast text · AAA", "$extensions": { "tr.tcm.wcag.aaa": true } },
      "12": { "$type": "color", "$value": "#000C24", "$description": "High-contrast text" }
    },
    "amber": {
      "$description": "Tebliğ Amber · Bakanlık Tebliğleri kademesi tanımlayıcı renk",
      "$extensions": {
        "tr.tcm.kaynak": "Bakanlık mührü teamülü",
        "tr.tcm.kilit": "LOCKED",
        "tr.tcm.tier": "teblig"
      },
      "1":  { "$type": "color", "$value": "#FEFCF8", "$description": "App background" },
      "2":  { "$type": "color", "$value": "#FDF7EB", "$description": "Subtle background · Tebliğ bg" },
      "3":  { "$type": "color", "$value": "#F9ECCF", "$description": "Element background" },
      "4":  { "$type": "color", "$value": "#F3DAA8", "$description": "Hover element bg" },
      "5":  { "$type": "color", "$value": "#EAC07A", "$description": "Active element bg" },
      "6":  { "$type": "color", "$value": "#DDA34F", "$description": "Subtle border" },
      "7":  { "$type": "color", "$value": "#CB8329", "$description": "UI element border" },
      "8":  { "$type": "color", "$value": "#BB6A14", "$description": "Hover border" },
      "9":  { "$type": "color", "$value": "#B45309", "$description": "Solid base · Tebliğ mührü", "$extensions": { "tr.tcm.kilit": "LOCKED" } },
      "10": { "$type": "color", "$value": "#963F03", "$description": "Hover solid" },
      "11": { "$type": "color", "$value": "#762D00", "$description": "Low-contrast text · AAA", "$extensions": { "tr.tcm.wcag.aaa": true } },
      "12": { "$type": "color", "$value": "#451900", "$description": "High-contrast text" }
    },
    "gri": {
      "$description": "Nötr Gri · UI omurgası · OKLCH neutral scale · 12 step",
      "$extensions": {
        "tr.tcm.kaynak": "OKLCH nötr scale",
        "tr.tcm.kilit": "LOCKED"
      },
      "1":  { "$type": "color", "$value": "#FCFCFC", "$description": "Page background · main surface" },
      "2":  { "$type": "color", "$value": "#F7F7F7", "$description": "Panel background · card bg" },
      "3":  { "$type": "color", "$value": "#EEEEEE", "$description": "Element background" },
      "4":  { "$type": "color", "$value": "#E0E0E0", "$description": "Hover element bg" },
      "5":  { "$type": "color", "$value": "#CCCCCC", "$description": "Section divider · table border" },
      "6":  { "$type": "color", "$value": "#B0B0B0", "$description": "Default UI border" },
      "7":  { "$type": "color", "$value": "#909090", "$description": "Strong border" },
      "8":  { "$type": "color", "$value": "#707070", "$description": "Hover border" },
      "9":  { "$type": "color", "$value": "#525252", "$description": "Muted text · description",       "$extensions": { "tr.tcm.tier": "genelge" } },
      "10": { "$type": "color", "$value": "#3D3D3D", "$description": "Strong muted text" },
      "11": { "$type": "color", "$value": "#262626", "$description": "Secondary text" },
      "12": { "$type": "color", "$value": "#0A0A0A", "$description": "Body text · AAA · ana mevzuat metni", "$extensions": { "tr.tcm.wcag.aaa": true } }
    }
  }
}
